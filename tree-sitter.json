{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "pdll",
      "camelcase": "PDLL",
      "title": "PDLL",
      "scope": "source.pdll",
      "file-types": ["pdll"],
      "injection-regex": "^pdll$",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "locals": "queries/locals.scm",
      "tags": "queries/tags.scm",
      "class-name": "TreeSitterPdll"
    }
  ],
  "metadata": {
    "version": "0.1.1",
    "license": "Apache-2.0 WITH LLVM-exception",
    "description": "PDLL grammar for tree-sitter",
    "authors": [
      {
        "name": "Buyun Xu",
        "email": "xubuyun@outlook.com",
        "url": "https://github.com/felixtensor"
      }
    ],
    "links": {
      "repository": "https://github.com/felixtensor/tree-sitter-pdll"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
